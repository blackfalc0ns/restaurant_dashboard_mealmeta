    "@angular/compiler-cli": "^19.2.0",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.3.0",
    "angular-eslint": "^19.8.1",
    "eslint": "^9.39.2",
    "postcss": "^8.5.15",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.46.0"
